{
  "name": "civil-engineer-backend",
  "version": "1.0.0",
  "description": "AI Civil Engineering Assistant - Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate --schema=../database/schema.prisma && tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=../database/schema.prisma",
    "prisma:push": "prisma db push --schema=../database/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../database/schema.prisma",
    "prisma:studio": "prisma studio --schema=../database/schema.prisma",
    "prisma:seed": "tsx src/seed.ts"
  },
  "keywords": [
    "civil-engineering",
    "api",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "prisma": "^5.22.0",
    "resend": "^4.0.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.1",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
